# ─────────────────────────────────────────────────────────────────────────────
# DJANGO
# ─────────────────────────────────────────────────────────────────────────────
DJANGO_SECRET_KEY=cambia-esta-clave-en-produccion
DJANGO_DEBUG=False
DJANGO_ALLOWED_HOSTS=localhost,127.0.0.1

# ─────────────────────────────────────────────────────────────────────────────
# BASE DE DATOS (PostgreSQL)
# ─────────────────────────────────────────────────────────────────────────────
DB_NAME=paros_produccion
DB_USER=postgres
DB_PASSWORD=cambia-esta-contraseña
DB_HOST=db
DB_PORT=5432

CSRF_TRUSTED_ORIGINS=http://localhost:8080

# ─────────────────────────────────────────────────────────────────────────────
# SUPERUSUARIO INICIAL
# ─────────────────────────────────────────────────────────────────────────────
DJANGO_SUPERUSER_USERNAME=admin
DJANGO_SUPERUSER_EMAIL=admin@empresa.com
DJANGO_SUPERUSER_PASSWORD=CambiaMiPassword123

# ─────────────────────────────────────────────────────────────────────────────
# RESPALDOS
# En Windows: ruta completa al ejecutable pg_dump
# En Linux/Coolify: solo "pg_dump" (ya está en el PATH)
# ─────────────────────────────────────────────────────────────────────────────
PGDUMP_PATH=pg_dump

# ─────────────────────────────────────────────────────────────────────────────
# NOTAS
# - Copia este archivo como .env y rellena los valores reales
# - NUNCA subas el archivo .env al repositorio
# - DB_HOST debe ser "db" cuando se ejecuta con Docker Compose
# - DB_HOST debe ser "localhost" cuando se ejecuta en local sin Docker
# - PGDUMP_PATH en Coolify debe ser solo "pg_dump"
# ─────────────────────────────────────────────────────────────────────────────